# Copy to .env (local) or set these in your host's dashboard (production).
# .env is gitignored — never commit real values.

GOOGLE_API_KEY=your-google-api-key-here

# Supabase connection string (Session pooler, port 5432).
# Note the +psycopg suffix — required by langchain-postgres.
DATABASE_URL=postgresql+psycopg://postgres.PROJECT:PASSWORD@HOST:5432/postgres

# In production, set this to your Vercel frontend URL.
ALLOWED_ORIGINS=*
